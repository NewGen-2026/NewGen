{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "~/components/*": [
        "src/components/*"
      ],
      "~/pages/*": [
        "src/pages/*"
      ],
      "~/hooks/*": [
        "src/hooks/*"
      ],
      "~/utils/*": [
        "src/utils/*"
      ],
      "~/assets/*": [
        "src/assets/*"
      ],
			"~/types/*": [
				"src/types/*"
			],
    },
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve"
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
		"**/*.js",
		"**/*.jsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
